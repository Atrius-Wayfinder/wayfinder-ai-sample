# Pinned Location (required for location-aware-agent, optional for chat-agent)
# Static kiosk position — the app will show a blue dot here and use it
# as the origin for directions and nearby search.
VITE_PINNED_LATITUDE=<latitude>
VITE_PINNED_LONGITUDE=<longitude>
VITE_PINNED_FLOOR_ID=<floor-id>
VITE_PINNED_TITLE=<display-title>
